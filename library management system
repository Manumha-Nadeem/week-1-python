import datetime
from typing import List, Optional


class Book:
    def __init__(self, isbn: str, title: str, author: str, total_copies: int = 1):
        self.isbn = isbn
        self.title = title
        self.author = author
        self.total_copies = total_copies
        self.available_copies = total_copies

    def is_available(self) -> bool:
        return self.available_copies > 0

    def __str__(self):
        return f"[{self.isbn}] {self.title} by {self.author} ({self.available_copies}/{self.total_copies} available)"


class Member:
    def __init__(self, member_id: str, name: str, email: str):
        self.member_id = member_id
        self.name = name
        self.email = email
        self.borrowed_books: List[str] = []

    def __str__(self):
        return f"[{self.member_id}] {self.name} <{self.email}> - {len(self.borrowed_books)} book(s) borrowed"


class Transaction:
    def __init__(self, isbn: str, member_id: str, borrow_date: datetime.date):
        self.isbn = isbn
        self.member_id = member_id
        self.borrow_date = borrow_date
        self.return_date: Optional[datetime.date] = None

    def close(self, return_date: datetime.date):
        self.return_date = return_date

    def __str__(self):
        status = f"returned on {self.return_date}" if self.return_date else "not yet returned"
        return f"ISBN {self.isbn} - Member {self.member_id} - borrowed {self.borrow_date} - {status}"


class Library:
    def __init__(self, name: str):
        self.name = name
        self.books = {}
        self.members = {}
        self.transactions: List[Transaction] = []

    def add_book(self, book: Book):
        if book.isbn in self.books:
            existing = self.books[book.isbn]
            existing.total_copies += book.total_copies
            existing.available_copies += book.total_copies
        else:
            self.books[book.isbn] = book
        print(f"Book added: {book.title}")

    def remove_book(self, isbn: str):
        if isbn in self.books:
            del self.books[isbn]
            print("Book removed successfully.")
        else:
            print("Book not found.")

    def register_member(self, member: Member):
        if member.member_id in self.members:
            print("Member ID already exists.")
            return
        self.members[member.member_id] = member
        print(f"Member registered: {member.name}")

    def remove_member(self, member_id: str):
        if member_id in self.members:
            if self.members[member_id].borrowed_books:
                print("Cannot remove member with outstanding borrowed books.")
                return
            del self.members[member_id]
            print("Member removed successfully.")
        else:
            print("Member not found.")

    def borrow_book(self, isbn: str, member_id: str):
        book = self.books.get(isbn)
        member = self.members.get(member_id)

        if not book:
            print("Book not found.")
            return
        if not member:
            print("Member not found.")
            return
        if not book.is_available():
            print("No available copies of this book.")
            return
        if isbn in member.borrowed_books:
            print("Member has already borrowed this book.")
            return

        book.available_copies -= 1
        member.borrowed_books.append(isbn)
        transaction = Transaction(isbn, member_id, datetime.date.today())
        self.transactions.append(transaction)
        print(f"{member.name} borrowed '{book.title}'.")

    def return_book(self, isbn: str, member_id: str):
        book = self.books.get(isbn)
        member = self.members.get(member_id)

        if not book or not member:
            print("Book or member not found.")
            return
        if isbn not in member.borrowed_books:
            print("This member did not borrow this book.")
            return

        member.borrowed_books.remove(isbn)
        book.available_copies += 1

        for transaction in reversed(self.transactions):
            if transaction.isbn == isbn and transaction.member_id == member_id and transaction.return_date is None:
                transaction.close(datetime.date.today())
                break

        print(f"{member.name} returned '{book.title}'.")

    def search_books(self, keyword: str) -> List[Book]:
        keyword = keyword.lower()
        results = [
            book for book in self.books.values()
            if keyword in book.title.lower()
            or keyword in book.author.lower()
            or keyword in book.isbn.lower()
        ]
        return results

    def list_books(self):
        if not self.books:
            print("No books in the library.")
            return
        for book in self.books.values():
            print(book)

    def list_members(self):
        if not self.members:
            print("No members registered.")
            return
        for member in self.members.values():
            print(member)

    def member_history(self, member_id: str):
        member = self.members.get(member_id)
        if not member:
            print("Member not found.")
            return
        history = [t for t in self.transactions if t.member_id == member_id]
        if not history:
            print("No transaction history for this member.")
            return
        for t in history:
            print(t)


def input_nonempty(prompt: str) -> str:
    value = input(prompt).strip()
    while not value:
        value = input("This field cannot be empty. " + prompt).strip()
    return value


def print_menu():
    print("\n===== Library Management System =====")
    print("1. Add Book")
    print("2. Remove Book")
    print("3. Register Member")
    print("4. Remove Member")
    print("5. Borrow Book")
    print("6. Return Book")
    print("7. Search Books")
    print("8. List All Books")
    print("9. List All Members")
    print("10. View Member History")
    print("0. Exit")


def main():
    library = Library("City Library")

    library.add_book(Book("978-0132350884", "Clean Code", "Robert C. Martin", 3))
    library.add_book(Book("978-0201633610", "Design Patterns", "Gang of Four", 2))
    library.register_member(Member("M001", "Alice Johnson", "alice@example.com"))
    library.register_member(Member("M002", "Bob Smith", "bob@example.com"))

    while True:
        print_menu()
        choice = input("Enter your choice: ").strip()

        if choice == "1":
            isbn = input_nonempty("Enter ISBN: ")
            title = input_nonempty("Enter title: ")
            author = input_nonempty("Enter author: ")
            try:
                copies = int(input("Enter number of copies (default 1): ") or 1)
            except ValueError:
                copies = 1
            library.add_book(Book(isbn, title, author, copies))

        elif choice == "2":
            isbn = input_nonempty("Enter ISBN to remove: ")
            library.remove_book(isbn)

        elif choice == "3":
            member_id = input_nonempty("Enter member ID: ")
            name = input_nonempty("Enter member name: ")
            email = input_nonempty("Enter member email: ")
            library.register_member(Member(member_id, name, email))

        elif choice == "4":
            member_id = input_nonempty("Enter member ID to remove: ")
            library.remove_member(member_id)

        elif choice == "5":
            isbn = input_nonempty("Enter ISBN to borrow: ")
            member_id = input_nonempty("Enter member ID: ")
            library.borrow_book(isbn, member_id)

        elif choice == "6":
            isbn = input_nonempty("Enter ISBN to return: ")
            member_id = input_nonempty("Enter member ID: ")
            library.return_book(isbn, member_id)

        elif choice == "7":
            keyword = input_nonempty("Enter search keyword (title/author/ISBN): ")
            results = library.search_books(keyword)
            if results:
                for book in results:
                    print(book)
            else:
                print("No matching books found.")

        elif choice == "8":
            library.list_books()

        elif choice == "9":
            library.list_members()

        elif choice == "10":
            member_id = input_nonempty("Enter member ID: ")
            library.member_history(member_id)

        elif choice == "0":
            print("Goodbye!")
            break

        else:
            print("Invalid choice. Please try again.")


if __name__ == "__main__":
    main()
